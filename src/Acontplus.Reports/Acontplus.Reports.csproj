<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
    <PackageId>Acontplus.Reports</PackageId>
    <Version>1.7.5</Version>
    <Authors>Ivan Paz</Authors>
    <Company>Acontplus</Company>
    <Product>Acontplus .NET Libraries</Product>
    <Copyright>Copyright © 2026 Acontplus</Copyright>
    <Description>Advanced library for comprehensive report generation and management. Includes RDLC
      report processing, PDF/Excel export capabilities, ReportViewer integration, QuestPDF dynamic
      PDF generation with fluent composition, MiniExcel high-performance streaming Excel exports,
      ClosedXML advanced richly formatted Excel workbooks with corporate styles, freeze panes,
      autofilter and formula aggregates, template support, and enterprise-ready reporting
      patterns for business applications.</Description>
    <PackageTags>
      dotnet;dotnet10;reports;rdl;rdlc;reporting;reportviewer;pdf;excel;questpdf;dynamic-pdf;fluent-pdf;miniexcel;closedxml;excel-export;excel-formatting;templates;business-intelligence;export;enterprise</PackageTags>
    <RepositoryUrl>https://github.com/acontplus/acontplus-dotnet-libs</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageProjectUrl>https://github.com/acontplus/acontplus-dotnet-libs</PackageProjectUrl>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageIcon>icon.png</PackageIcon>
    <PackageReleaseNotes>v1.7.0: Added dual Excel report generation engines — MiniExcel
      (IMiniExcelReportService) for high-performance, stream-based bulk exports with minimal memory
      overhead, and ClosedXML (IClosedXmlReportService) for advanced richly formatted workbooks with
      corporate header styles, freeze panes, AutoFilter, alternating row shading, aggregate formula
      totals rows, multi-sheet workbooks, and workbook metadata. Both engines include concurrency
      control, timeout protection, and full DI integration.</PackageReleaseNotes>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <DocumentationFile>$(OutputPath)$(AssemblyName).xml</DocumentationFile>
    <NoWarn>$(NoWarn);1591</NoWarn>
    <LangVersion>latest</LangVersion>
    <AnalysisLevel>latest</AnalysisLevel>
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
    <AssemblyVersion>1.0.0.0</AssemblyVersion>

    <!-- SourceLink configuration for enterprise-grade debugging -->
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>

    <!-- Deterministic builds (CI only: GitHub Actions or Azure DevOps) -->
    <ContinuousIntegrationBuild Condition="'$(CI)' == 'true' or '$(TF_BUILD)' == 'true'">true</ContinuousIntegrationBuild>
  </PropertyGroup>
  <ItemGroup>
    <None Remove="README.md" />
    <None Remove="Resources\NotFound.pdf" />
  </ItemGroup>
  <ItemGroup>
    <Content Include="README.md">
      <PackagePath>\</PackagePath>
      <Pack>true</Pack>
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </Content>
  </ItemGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
    <PackageReference Include="Acontplus.Barcode" />
    <PackageReference Include="Acontplus.Utilities" />
    <PackageReference Include="ClosedXML" />
    <PackageReference Include="MiniExcel" />
    <PackageReference Include="QuestPDF" />
    <PackageReference Include="ReportViewerCore.NETCore" />
  </ItemGroup>
  <ItemGroup>
    <Content Include="Resources\NotFound.pdf">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </Content>
  </ItemGroup>
  <ItemGroup>
    <EmbeddedResource Include="Images\icon.png">
      <PackagePath>\</PackagePath>
      <Pack>True</Pack>
    </EmbeddedResource>
  </ItemGroup>
</Project>
